# Hermes Web UI Configuration Example
# Copy this file to .env and customize as needed

# Server Configuration
HERMES_WEBUI_HOST=127.0.0.1
HERMES_WEBUI_PORT=8787

# Security
# Set a password to protect the Web UI (recommended for remote access)
# HERMES_WEBUI_PASSWORD=your_s...word

# Agent Configuration
# Auto-detected: %USERPROFILE%\AppData\Local\hermes\hermes-agent
# HERMES_WEBUI_AGENT_DIR=C:\custom\path\to\hermes-agent

# Workspace Configuration
# Auto-detected: %USERPROFILE%\workspace
# HERMES_WORKSPACE=D:\your\workspace

# Debugging
# HERMES_WEBUI_DEBUG=1
# HERMES_WEBUI_LOG_LEVEL=debug

# Authentication
# HERMES_WEBUI_AUTH_MODE=password
# HERMES_WEBUI_AUTH_MODE=webauthn

# Pre-fill Messages (Optional)
# HERMES_PREFILL_MESSAGES_FILE=prefill_messages.json

# Session Prefill Script (Optional)
# HERMES_WEBUI_PREFILL_MESSAGES_SCRIPT=python3 /path/to/notes_recall.py
# HERMES_WEBUI_PREFILL_MESSAGES_SCRIPT_TIMEOUT=5

# Note: Environment variables set here override defaults
# but can be overridden by system environment variables